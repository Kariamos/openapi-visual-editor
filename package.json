{
  "name": "openapi-visual-editor",
  "displayName": "OpenAPI Visual Editor",
  "description": "A graphical editor for OpenAPI/Swagger YAML specifications",
  "version": "1.0.0",
  "publisher": "Kariamos",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kariamos/openapi-visual-editor.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "openapi",
    "swagger",
    "yaml",
    "rest",
    "api"
  ],
  "activationEvents": [
    "onLanguage:yaml",
    "onLanguage:json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openapi-visual-editor.openVisualEditor",
        "title": "Open Visual Editor",
        "icon": "$(eye)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "openapi-visual-editor.openVisualEditor",
          "when": "resourceExtname == .yml || resourceExtname == .yaml",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "build:webview": "cd webview && npm run build",
    "build:all": "npm run build:webview && npm run compile",
    "pretest": "npm run compile"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
